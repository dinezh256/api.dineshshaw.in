NODE_ENV=development
PORT=3000
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URL_LOCAL=mongodb://localhost:27017
MONGODB_DB_NAME=portfolio
JWT_PRIVATE_KEY=replace-me
SALT_ROUNDS=10
CORS_ORIGINS=https://api.dineshshaw.in,https://dineshshaw.in,https://www.dineshshaw.in,http://localhost:3000
TRUST_PROXY_HOPS=1
JSON_BODY_LIMIT=100kb
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
VIEWS_RATE_LIMIT_WINDOW_MS=60000
VIEWS_RATE_LIMIT_MAX=30
VIEW_COUNT_CACHE_TTL_MS=0
ENABLE_AUTH_ROUTES=false
JWT_EXPIRES_IN=7d
