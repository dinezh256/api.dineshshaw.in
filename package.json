{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.33.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test MONGODB_URL=mongodb://127.0.0.1:27017 CORS_ORIGINS=http://localhost:3000 JWT_PRIVATE_KEY=test-secret node --import tsx --test src/*.test.ts src/middleware/*.test.ts src/routes/schemas/*.test.ts",
    "dev": "NODE_ENV=development tsx watch src/server.ts"
  },
  "author": "",
